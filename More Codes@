import { useState } from 'react';
import axios from 'axios';

export default function QuoteForm() {
  const [form, setForm] = useState({ name: '', age: '', income: '' });

  const submit = async () => {
    const res = await axios.post('/api/leads', form);
    alert(`Recommended: ${res.data.recommendedPlan}`);
  };

  return (
    <div>
      <input placeholder="Name" onChange={e => setForm({...form, name: e.target.value})} />
      <input placeholder="Age" onChange={e => setForm({...form, age: e.target.value})} />
      <input placeholder="Income" onChange={e => setForm({...form, income: e.target.value})} />
      <button onClick={submit}>Get Quote</button>
    </div>
  );
}
